# Liveblocks
# Get your keys from https://liveblocks.io/dashboard/apikeys
LIVEBLOCKS_SECRET_KEY=sk_dev_xxxxx
NEXT_PUBLIC_LIVEBLOCKS_PUBLIC_KEY=pk_dev_xxxxx

# Clerk Authentication
# For development: use pk_test_ and sk_test_ keys
# For production: use pk_live_ and sk_live_ keys
# See: https://clerk.com/docs/guides/development/deployment/production
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
CLERK_SECRET_KEY=sk_test_xxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# GetStream Video
# Get your keys from https://getstream.io/dashboard
NEXT_PUBLIC_STREAM_API_KEY=xxxxx
STREAM_SECRET_KEY=xxxxx
